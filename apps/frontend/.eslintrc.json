{
  "extends": ["next/core-web-vitals", "plugin:jsx-a11y/recommended", "prettier"],
  "overrides": [
    {
      "files": ["src/stores/**/*.ts", "src/stores/**/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["../components/*", "../../components/*", "../../../components/*"]
          }
        ]
      }
    }
  ]
}
